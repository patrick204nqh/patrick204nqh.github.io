---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404">
  <div class="max-w-[42rem] mx-auto px-6 py-32 text-center">
    <h1 class="font-display text-6xl font-semibold text-accent mb-4">404</h1>
    <p class="text-ink-dim text-lg mb-8">Lost at sea. This page doesn't exist.</p>
    <a href="/" class="font-mono text-xs text-accent no-underline border border-accent/30 rounded-pill px-6 py-3 transition-all duration-300 hover:bg-accent/10 hover:border-accent">
      Back to shore
    </a>
  </div>
</Layout>
