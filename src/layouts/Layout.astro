---
import '../styles/globals.css';
import Nav from '../components/Nav';
import Footer from '../components/Footer.astro';

export interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title ? `${title} — PATRICK204NQH` : 'PATRICK204NQH'}</title>
  </head>
  <body class="bg-surface text-ink min-h-screen">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Nav client:load />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
