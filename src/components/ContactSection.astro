---
const contacts = [
  { href: 'mailto:patrick204nqh@gmail.com', label: 'Email', value: 'patrick204nqh@gmail.com', svg: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/></svg>' },
  { href: 'https://github.com/patrick204nqh', label: 'GitHub', value: '@patrick204nqh', svg: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22"/></svg>' },
  { href: 'https://linkedin.com/in/patrick204nqh', label: 'LinkedIn', value: 'in/patrick204nqh', svg: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>' },
];
---

<section class="page-section relative z-10 py-24 bg-surface" id="contact">
  <div class="max-w-[42rem] mx-auto px-6">
    <p class="font-mono text-[0.7rem] tracking-[2.5px] uppercase text-accent/80 mb-3 reveal">Reach out</p>
    <h2 class="font-display text-[clamp(1.5rem,3vw,2.25rem)] font-semibold tracking-[-0.75px] leading-[1.2] mb-6 max-w-[28ch] reveal reveal-delay-1">Let's chart a course together.</h2>
    <div class="text-ink-dim leading-relaxed max-w-[60ch] text-sm reveal reveal-delay-2">
      <p>Project idea, collaboration, or just to say hello. The inbox is always open.</p>
    </div>
    <div class="flex flex-col gap-3 mt-8">
      {contacts.map((c, i) => (
        <a href={c.href} class="flex items-center gap-4 px-5 py-4 rounded-[14px] text-ink no-underline bg-surface border border-border transition-all duration-300 hover:border-accent hover:bg-accent-dim hover:translate-x-1 max-w-[28rem] reveal {i > 0 ? `reveal-delay-${i}` : ''}">
          <span class="opacity-60 w-6 shrink-0 text-center" set:html={c.svg} />
          <span class="flex flex-col gap-0.5">
            <span class="text-xs text-ink-dim font-mono uppercase tracking-wide">{c.label}</span>
            <span class="font-mono text-sm text-ink">{c.value}</span>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
